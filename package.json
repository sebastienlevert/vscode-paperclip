{
  "name": "paperclipped",
  "displayName": "Paperclipped",
  "description": "A better integration for VS Code and productivity documents — share files, open in Word, Excel, PowerPoint, preview Office docs, and open on the web",
  "version": "1.1.0",
  "publisher": "sebastienlevert",
  "license": "MIT",
  "icon": "paperclipped.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastienlevert/paperclipped.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Paperclipped",
    "sharing",
    "office",
    "word",
    "excel",
    "powerpoint"
  ],
  "os": [
    "win32"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "paperclipped.share",
        "title": "Share",
        "category": "Paperclipped",
        "icon": {
          "light": "resources/icons/share.svg",
          "dark": "resources/icons/share.svg"
        }
      },
      {
        "command": "paperclipped.openInWord",
        "title": "Open in Word",
        "category": "Paperclipped",
        "icon": {
          "light": "resources/icons/word.svg",
          "dark": "resources/icons/word.svg"
        }
      },
      {
        "command": "paperclipped.openInExcel",
        "title": "Open in Excel",
        "category": "Paperclipped",
        "icon": {
          "light": "resources/icons/excel.svg",
          "dark": "resources/icons/excel.svg"
        }
      },
      {
        "command": "paperclipped.openInPowerPoint",
        "title": "Open in PowerPoint",
        "category": "Paperclipped",
        "icon": {
          "light": "resources/icons/powerpoint.svg",
          "dark": "resources/icons/powerpoint.svg"
        }
      },
      {
        "command": "paperclipped.openOnWeb",
        "title": "Open on Web",
        "category": "Paperclipped",
        "icon": {
          "light": "resources/icons/web.svg",
          "dark": "resources/icons/web.svg"
        }
      },
      {
        "command": "paperclipped.openFolderOnWeb",
        "title": "Open Folder on Web",
        "category": "Paperclipped"
      },
      {
        "command": "paperclipped.versionHistory",
        "title": "Version History",
        "category": "Paperclipped"
      },
      {
        "command": "paperclipped.recentFiles",
        "title": "Recent Files",
        "category": "Paperclipped"
      },
      {
        "command": "paperclipped.copySharingLink",
        "title": "Copy Sharing Link",
        "category": "Paperclipped"
      },
      {
        "command": "paperclipped.exportToWord",
        "title": "Export to Word",
        "category": "Paperclipped"
      }
    ],
    "submenus": [
      {
        "id": "paperclipped.menu",
        "label": "Paperclipped"
      },
      {
        "id": "paperclipped.folderMenu",
        "label": "Paperclipped"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "paperclipped.menu",
          "when": "paperclipped:isOneDriveWorkspace && !explorerResourceIsFolder",
          "group": "navigation@100"
        },
        {
          "submenu": "paperclipped.folderMenu",
          "when": "paperclipped:isOneDriveWorkspace && explorerResourceIsFolder",
          "group": "navigation@100"
        }
      ],
      "editor/title/context": [
        {
          "submenu": "paperclipped.menu",
          "when": "paperclipped:isOneDriveWorkspace",
          "group": "navigation@100"
        }
      ],
      "paperclipped.menu": [
        {
          "command": "paperclipped.share",
          "group": "1_share"
        },
        {
          "command": "paperclipped.copySharingLink",
          "group": "1_share"
        },
        {
          "command": "paperclipped.openInWord",
          "when": "resourceExtname == .doc || resourceExtname == .docx || resourceExtname == .docm || resourceExtname == .dot || resourceExtname == .dotx || resourceExtname == .dotm || resourceExtname == .rtf",
          "group": "2_openApp"
        },
        {
          "command": "paperclipped.openInExcel",
          "when": "resourceExtname == .xls || resourceExtname == .xlsx || resourceExtname == .xlsm || resourceExtname == .xlsb || resourceExtname == .xlt || resourceExtname == .xltx || resourceExtname == .xltm || resourceExtname == .csv",
          "group": "2_openApp"
        },
        {
          "command": "paperclipped.openInPowerPoint",
          "when": "resourceExtname == .ppt || resourceExtname == .pptx || resourceExtname == .pptm || resourceExtname == .pot || resourceExtname == .potx || resourceExtname == .potm || resourceExtname == .ppsx || resourceExtname == .ppsm || resourceExtname == .pps",
          "group": "2_openApp"
        },
        {
          "command": "paperclipped.openOnWeb",
          "group": "3_web"
        },
        {
          "command": "paperclipped.openFolderOnWeb",
          "group": "3_web"
        },
        {
          "command": "paperclipped.versionHistory",
          "group": "4_history"
        },
        {
          "command": "paperclipped.exportToWord",
          "when": "resourceExtname == .md",
          "group": "5_export"
        }
      ],
      "paperclipped.folderMenu": [
        {
          "command": "paperclipped.openFolderOnWeb",
          "group": "1_web"
        }
      ],
      "commandPalette": [
        {
          "command": "paperclipped.share",
          "when": "paperclipped:isOneDriveWorkspace"
        },
        {
          "command": "paperclipped.openInWord",
          "when": "paperclipped:isOneDriveWorkspace && resourceExtname =~ /^\\.(doc|docx|docm|dot|dotx|dotm|rtf)$/i"
        },
        {
          "command": "paperclipped.openInExcel",
          "when": "paperclipped:isOneDriveWorkspace && resourceExtname =~ /^\\.(xls|xlsx|xlsm|xlsb|xlt|xltx|xltm|csv)$/i"
        },
        {
          "command": "paperclipped.openInPowerPoint",
          "when": "paperclipped:isOneDriveWorkspace && resourceExtname =~ /^\\.(ppt|pptx|pptm|pot|potx|potm|ppsx|ppsm|pps)$/i"
        },
        {
          "command": "paperclipped.openOnWeb",
          "when": "paperclipped:isOneDriveWorkspace"
        },
        {
          "command": "paperclipped.openFolderOnWeb",
          "when": "paperclipped:isOneDriveWorkspace"
        },
        {
          "command": "paperclipped.versionHistory",
          "when": "paperclipped:isOneDriveWorkspace"
        },
        {
          "command": "paperclipped.recentFiles",
          "when": "paperclipped:isOneDriveWorkspace"
        },
        {
          "command": "paperclipped.copySharingLink",
          "when": "paperclipped:isOneDriveWorkspace"
        },
        {
          "command": "paperclipped.exportToWord",
          "when": "resourceExtname =~ /^\\.md$/i"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "paperclipped.officePreview",
        "displayName": "Office Document Preview (Paperclipped)",
        "selector": [
          {
            "filenamePattern": "*.doc"
          },
          {
            "filenamePattern": "*.docx"
          },
          {
            "filenamePattern": "*.docm"
          },
          {
            "filenamePattern": "*.dot"
          },
          {
            "filenamePattern": "*.dotx"
          },
          {
            "filenamePattern": "*.dotm"
          },
          {
            "filenamePattern": "*.rtf"
          },
          {
            "filenamePattern": "*.xls"
          },
          {
            "filenamePattern": "*.xlsx"
          },
          {
            "filenamePattern": "*.xlsm"
          },
          {
            "filenamePattern": "*.xlsb"
          },
          {
            "filenamePattern": "*.xlt"
          },
          {
            "filenamePattern": "*.xltx"
          },
          {
            "filenamePattern": "*.xltm"
          },
          {
            "filenamePattern": "*.ppt"
          },
          {
            "filenamePattern": "*.pptx"
          },
          {
            "filenamePattern": "*.pptm"
          },
          {
            "filenamePattern": "*.pot"
          },
          {
            "filenamePattern": "*.potx"
          },
          {
            "filenamePattern": "*.potm"
          },
          {
            "filenamePattern": "*.ppsx"
          },
          {
            "filenamePattern": "*.ppsm"
          },
          {
            "filenamePattern": "*.pps"
          },
          {
            "filenamePattern": "*.pdf"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --allow-missing-repository",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "esbuild": "^0.20.0",
    "@vscode/vsce": "^2.22.0"
  }
}
